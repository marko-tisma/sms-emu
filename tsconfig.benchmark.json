{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "lib": ["ES2021", "DOM"],
    "moduleResolution": "Node",
    "strict": true,
    "sourceMap": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noEmit": false,
    "outDir": ".benchmark-dist",
    "noImplicitReturns": true,
    "noImplicitAny": true,
    "noImplicitThis": true
  },
  "include": ["./src", "./benchmark"]
}
